{
  "name": "terminal-code-reviewer",
  "version": "0.1.0",
  "description": "A TypeScript CLI that reviews git diffs in the terminal.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "terminal-code-reviewer": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "code-review",
    "git",
    "diff",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.2.3",
    "openai": "^6.9.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.13"
  }
}
